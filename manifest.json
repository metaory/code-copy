{
  "name": "Code Copy",
  "short_name": "codecopy",
  "description": "Click code blocks to copy. Hold Ctrl and click any element to copy its text.",
  "version": "0.5.0",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": {
    "email": "metaory@gmail.com"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://0.0.0.0/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
